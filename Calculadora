package com.example.miapp;
//Eduardo Dominguez Cuapio
//Programación Movil 1
import android.app.Activity;
import android.graphics.Color;
import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;
import android.widget.LinearLayout;
import android.widget.TextView;

public class Calculadora extends Activity implements View.OnClickListener {
    Button[] btnDigitos = new Button[10];
    int col = 0;
    boolean pintarPunto = true;
    EditText pantalla;
    TextView cuadro;
    double op1, op2, res;
    Button btnSuma, btnResta, btnMult, btnDiv, btnPunto, btnIgual, btnBorrar;
    int operacion = 0; // 1:+, 2:-, 3:*, 4:/

    protected void onCreate(Bundle b) {
        super.onCreate(b);
        LinearLayout panelPrincipal = new LinearLayout(this);
        panelPrincipal.setBackgroundColor(Color.BLACK);
        panelPrincipal.setOrientation(LinearLayout.VERTICAL);

        LinearLayout panelPantalla = new LinearLayout(this);
        panelPantalla.setOrientation(LinearLayout.VERTICAL);
        panelPantalla.setBackgroundColor(Color.GRAY);
        panelPantalla.setMinimumHeight(200);

        cuadro = new TextView(this);
        cuadro.setBackgroundColor(Color.BLUE);
        cuadro.setText(" ");
        cuadro.setMinimumHeight(50);
        cuadro.setTextColor(Color.WHITE);      // ← texto visible sobre azul
        cuadro.setTextSize(18);

        pantalla = new EditText(this);
        pantalla.setTextColor(Color.WHITE);
        pantalla.setTextSize(40);
        pantalla.setMaxLines(1);
        pantalla.setTextAlignment(EditText.TEXT_ALIGNMENT_TEXT_END);

        panelPantalla.addView(cuadro);
        panelPantalla.addView(pantalla);

        LinearLayout panelControles = new LinearLayout(this);
        panelControles.setBackgroundColor(Color.RED);

        LinearLayout panelBotones1 = new LinearLayout(this);
        panelBotones1.setBackgroundColor(Color.WHITE);
        panelBotones1.setOrientation(LinearLayout.VERTICAL);
        LinearLayout panelBotones2 = new LinearLayout(this);
        panelBotones2.setOrientation(LinearLayout.VERTICAL);
        panelBotones2.setBackgroundColor(Color.GREEN);

        LinearLayout li1 = new LinearLayout(this);
        LinearLayout li2 = new LinearLayout(this);
        LinearLayout li3 = new LinearLayout(this);
        LinearLayout li4 = new LinearLayout(this);

        for (int i = 0; i <= 9; i++) {
            btnDigitos[i] = new Button(this);
            btnDigitos[i].setText(i + "");
            btnDigitos[i].setOnClickListener(this);

            switch (i) {
                case 0:
                    li4.addView(btnDigitos[i]);
                    break;
                case 1:
                case 2:
                case 3:
                    li3.addView(btnDigitos[i]);
                    break;
                case 4:
                case 5:
                case 6:
                    li2.addView(btnDigitos[i]);
                    break;
                case 7:
                case 8:
                case 9:
                    li1.addView(btnDigitos[i]);
                    break;
            }
            col = col + 1;
        }

        btnPunto = new Button(this);
        btnPunto.setText(".");
        btnPunto.setOnClickListener(this);

        btnIgual = new Button(this);
        btnIgual.setText("=");
        btnIgual.setOnClickListener(this);

        li4.addView(btnPunto);
        li4.addView(btnIgual);

        btnSuma = new Button(this);
        btnSuma.setText("+");
        btnSuma.setOnClickListener(this);

        btnResta = new Button(this);
        btnResta.setText("-");
        btnResta.setOnClickListener(this);

        btnMult = new Button(this);
        btnMult.setText("x");
        btnMult.setOnClickListener(this);

        btnDiv = new Button(this);
        btnDiv.setText("÷");
        btnDiv.setOnClickListener(this);

        btnBorrar = new Button(this);
        btnBorrar.setText("Borrar");
        btnBorrar.setOnClickListener(this);

        panelBotones1.addView(li1);
        panelBotones1.addView(li2);
        panelBotones1.addView(li3);
        panelBotones1.addView(li4);

        panelBotones2.addView(btnSuma);
        panelBotones2.addView(btnResta);
        panelBotones2.addView(btnMult);
        panelBotones2.addView(btnDiv);
        panelBotones2.addView(btnBorrar);

        panelPrincipal.addView(panelPantalla);
        panelControles.addView(panelBotones1);
        panelControles.addView(panelBotones2);
        panelPrincipal.addView(panelControles);

        setContentView(panelPrincipal);
    }

    // ─────────────────────────────────────────────
    // NUEVO: actualiza el cuadro en tiempo real
    // mientras el usuario escribe dígitos o el punto
    // ─────────────────────────────────────────────
    private void actualizarCuadro(String digito) {
        // 1. Agrega el dígito/punto a la pantalla
        pantalla.setText(pantalla.getText() + digito);

        // 2. Refleja en el cuadro según el estado
        if (operacion != 0) {
            // Ya se eligió un operador: muestra "op1 <operador> lo_que_se_escribe"
            String simbolo = "";
            switch (operacion) {
                case 1: simbolo = " + "; break;
                case 2: simbolo = " - "; break;
                case 3: simbolo = " x "; break;
                case 4: simbolo = " ÷ "; break;
            }
            cuadro.setText(op1 + simbolo + pantalla.getText());
        } else {
            // Aún no hay operador: solo muestra lo que se va escribiendo
            cuadro.setText(pantalla.getText());
        }
    }

    public void onClick(View v) {

        // ── Dígitos 0‑9 (reemplaza los 10 bloques if repetitivos) ──
        for (int i = 0; i <= 9; i++) {
            if (v.equals(btnDigitos[i])) {
                actualizarCuadro(i + "");
                return;
            }
        }

        // ── Punto decimal ──
        if (v.equals(btnPunto)) {
            if (pintarPunto) {
                actualizarCuadro(".");
                pintarPunto = false;
            }
        }

        // ── Suma ──
        if (v.equals(btnSuma)) {
            operacion = 1;
            pintarPunto = true;
            op1 = Double.parseDouble(pantalla.getText() + "");
            cuadro.setText(op1 + " + ");
            pantalla.setText("");
        }

        // ── Resta ──
        if (v.equals(btnResta)) {
            operacion = 2;
            pintarPunto = true;
            op1 = Double.parseDouble(pantalla.getText() + "");
            cuadro.setText(op1 + " - ");
            pantalla.setText("");
        }

        // ── Multiplicación ──
        if (v.equals(btnMult)) {
            operacion = 3;
            pintarPunto = true;
            op1 = Double.parseDouble(pantalla.getText() + "");
            cuadro.setText(op1 + " x ");
            pantalla.setText("");
        }

        // ── División ──
        if (v.equals(btnDiv)) {
            operacion = 4;
            pintarPunto = true;
            op1 = Double.parseDouble(pantalla.getText() + "");
            cuadro.setText(op1 + " ÷ ");
            pantalla.setText("");
        }

        // ── Borrar (reset completo) ──
        if (v.equals(btnBorrar)) {
            pantalla.setText("");
            cuadro.setText(" ");
            op1 = 0;
            op2 = 0;
            operacion = 0;
            pintarPunto = true;
        }

        // ── Igual ──
        if (v.equals(btnIgual)) {
            // Evita crash si la pantalla está vacía
            if (pantalla.getText().toString().isEmpty()) return;

            pintarPunto = true;
            op2 = Double.parseDouble(pantalla.getText() + "");

            // Muestra la operación completa antes del resultado
            String simbolo = "";
            switch (operacion) {
                case 1: simbolo = " + "; break;
                case 2: simbolo = " - "; break;
                case 3: simbolo = " x "; break;
                case 4: simbolo = " ÷ "; break;
            }
            cuadro.setText(op1 + simbolo + op2 + " =");

            // Calcula el resultado
            switch (operacion) {
                case 1: res = op1 + op2; break;
                case 2: res = op1 - op2; break;
                case 3: res = op1 * op2; break;
                case 4:
                    if (op2 != 0) {
                        res = op1 / op2;
                    } else {
                        pantalla.setText("Error: ÷ 0");
                        cuadro.setText(" ");
                        operacion = 0;
                        return;
                    }
                    break;
            }

            // Muestra el resultado; si es entero, omite el ".0"
            if (res == (long) res) {
                pantalla.setText(String.valueOf((long) res));
            } else {
                pantalla.setText(String.valueOf(res));
            }

            // Permite encadenar: el resultado se convierte en op1
            op1 = res;
            operacion = 0;
        }
    }
}
